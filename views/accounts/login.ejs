<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= pageTitle %> – FetchIT</title>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/accounts.css" />
</head>
<body>

<nav>
  <a class="nav-logo" href="/">🐾 FetchIT</a>
  <ul class="nav-links">
    <li><a href="/">Home</a></li>
    <li><a href="/products">Products</a></li>
    <li><a href="/signup" class="nav-cta">Sign Up</a></li>
  </ul>
</nav>

<div class="account-page">
  <div class="account-card">
    <h1 class="account-card-title">Welcome Back</h1>
    <p class="account-card-subtitle">Sign in to your FetchIT account.</p>

    <% if (error) { %>
      <div class="alert alert-error"><%= error %></div>
    <% } %>

    <form method="POST" action="/login">
      <div class="form-group">
        <label class="form-label" for="email">Email Address <span class="required">*</span></label>
        <input class="form-input" type="email" id="email" name="email" value="<%= formData.email || '' %>" required autofocus />
      </div>

      <div class="form-group">
        <label class="form-label" for="password">Password <span class="required">*</span></label>
        <input class="form-input" type="password" id="password" name="password" required />
      </div>

      <button type="submit" class="btn-primary">Sign In</button>
    </form>

    <div class="account-footer">
      Don't have an account? <a href="/signup">Create one here.</a>
    </div>
  </div>
</div>

</body>
</html>
