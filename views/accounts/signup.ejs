<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= pageTitle %> – FetchIT</title>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/accounts.css" />
</head>
<body>

<nav>
  <a class="nav-logo" href="/">🐾 FetchIT</a>
  <ul class="nav-links">
    <li><a href="/">Home</a></li>
    <li><a href="/products">Products</a></li>
    <li><a href="/login">Sign In</a></li>
  </ul>
</nav>

<div class="account-page">
  <div class="account-card">
    <h1 class="account-card-title">Create Account</h1>
    <p class="account-card-subtitle">Join FetchIT and start shopping for your pets.</p>

    <% if (error) { %>
      <div class="alert alert-error"><%= error %></div>
    <% } %>

    <form method="POST" action="/signup">

      <!-- Basic Info -->
      <div class="form-group">
        <label class="form-label" for="name">Full Name <span class="required">*</span></label>
        <input class="form-input" type="text" id="name" name="name" value="<%= formData.name || '' %>" required />
      </div>

      <div class="form-group">
        <label class="form-label" for="email">Email Address <span class="required">*</span></label>
        <input class="form-input" type="email" id="email" name="email" value="<%= formData.email || '' %>" required />
      </div>

      <div class="form-row">
        <div class="form-group">
          <label class="form-label" for="password">Password <span class="required">*</span></label>
          <input class="form-input" type="password" id="password" name="password" required />
          <p class="form-hint">At least 6 characters.</p>
        </div>
        <div class="form-group">
          <label class="form-label" for="confirmPassword">Confirm Password <span class="required">*</span></label>
          <input class="form-input" type="password" id="confirmPassword" name="confirmPassword" required />
        </div>
      </div>

      <!-- Contact -->
      <div class="form-section">
        <p class="form-section-title">Contact & Address <span style="font-weight:300;font-style:italic;">(optional)</span></p>
      </div>

      <div class="form-group">
        <label class="form-label" for="contact_number">Phone Number</label>
        <input class="form-input" type="tel" id="contact_number" name="contact_number" value="<%= formData.contact_number || '' %>" placeholder="09XXXXXXXXX" />
      </div>

      <div class="form-row">
        <div class="form-group">
          <label class="form-label" for="street_number">Street / Unit No.</label>
          <input class="form-input" type="text" id="street_number" name="street_number" value="<%= formData.street_number || '' %>" />
        </div>
        <div class="form-group">
          <label class="form-label" for="city">City</label>
          <input class="form-input" type="text" id="city" name="city" value="<%= formData.city || '' %>" />
        </div>
      </div>

      <div class="form-row">
        <div class="form-group">
          <label class="form-label" for="district">District / Barangay</label>
          <input class="form-input" type="text" id="district" name="district" value="<%= formData.district || '' %>" />
        </div>
        <div class="form-group">
          <label class="form-label" for="province">Province</label>
          <input class="form-input" type="text" id="province" name="province" value="<%= formData.province || '' %>" />
        </div>
      </div>

      <div class="form-group">
        <label class="form-label" for="postal_code">Postal Code</label>
        <input class="form-input" type="text" id="postal_code" name="postal_code" value="<%= formData.postal_code || '' %>" placeholder="e.g. 1630" />
      </div>

      <button type="submit" class="btn-primary">Create Account</button>
    </form>

    <div class="account-footer">
      Already have an account? <a href="/login">Sign in here.</a>
    </div>
  </div>
</div>

</body>
</html>
